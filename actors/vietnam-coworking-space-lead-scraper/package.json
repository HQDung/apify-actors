{
    "name": "vietnam-coworking-space-lead-scraper",
    "version": "0.0.1",
    "type": "module",
    "description": "Scrape coworking space leads from Google Maps in Vietnam and extract emails when available.",
    "dependencies": {
        "apify": "^3.7.0",
        "playwright": "1.60.0"
    },
    "devDependencies": {
        "@apify/eslint-config": "^2.0.0",
        "@crawlee/playwright": "^3.15.3",
        "eslint": "^9.29.0",
        "eslint-config-prettier": "^10.1.5",
        "prettier": "^3.5.3",
        "vitest": "^4.1.0"
    },
    "scripts": {
        "start": "node src/main.js",
        "format": "prettier --write .",
        "format:check": "prettier --check .",
        "lint": "eslint",
        "lint:fix": "eslint --fix",
        "test": "vitest run",
        "postinstall": "npx crawlee install-playwright-browsers"
    },
    "author": "It's not you it's me",
    "license": "ISC"
}
